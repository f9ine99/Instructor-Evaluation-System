# HOPE Evaluation System - Database Configuration
# Copy this file to .env and fill in your credentials

# Local MariaDB / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ievaluation
DB_USER=root
DB_PASS=

# For TiDB Cloud or other SSL-required hosts, set DB_SSL=true and DB_SSL_CA
# DB_SSL=false
# DB_SSL_CA=

# Required: anonymized submission tokens (HMAC). Generate: openssl rand -hex 32
# Do not use placeholder values; minimum 32 characters.
APP_SECRET=

# Session configuration
SESSION_LIFETIME=3600
# Optional: writable directory for file sessions (if system default is not writable, e.g. php built-in server)
# SESSION_SAVE_PATH=/run/user/1000/php-sessions
